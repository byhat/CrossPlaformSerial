<?xml version="1.0" encoding="utf-8"?>
<!--
  Optional USB device filter for the Qt-on-Android build. When wired into the app's
  AndroidManifest.xml (see README), Android offers cps_qt_serial as the handler when
  one of these USB-serial adapters is plugged in, and the permission dialog is shown
  automatically.

  Enumeration + connection work WITHOUT this (cps requests permission at open time);
  this only improves the plug-in UX. vendor-id values are decimal.
-->
<resources>
    <usb-device vendor-id="1027" />  <!-- 0x0403 FTDI FT232/FT2232/... -->
    <usb-device vendor-id="1659" />  <!-- 0x067B Prolific PL2303 -->
    <usb-device vendor-id="6790" />  <!-- 0x1A86 CH340/CH341 -->
    <usb-device vendor-id="4292" />  <!-- 0x10C4 Silicon Labs CP210x -->
    <usb-device vendor-id="1155" />  <!-- 0x0483 STMicroelectronics -->
    <usb-device vendor-id="11914" /> <!-- 0x2E8A Raspberry Pi Pico -->
    <usb-device vendor-id="9114" />  <!-- 0x239A Adafruit -->
    <usb-device vendor-id="7504" />  <!-- 0x1D50 OpenMoko/open-source -->
    <usb-device vendor-id="5256" />  <!-- RC SAF405 -->
</resources>
